{
	"base": {
		"manifest_version": 3,
		"name": "__MSG_name__",
		"description": "__MSG_description__",
		"default_locale": "en",
		"version": "1.0.8",
		"author": "Sleezzi",
		"homepage_url": "https://sleezzi.fr",
		"action": {
			"default_title": "Open settings"
		},
		"icons": {
			"128": "/img/Icon_128.png",
			"48": "/img/Icon_48.png",
			"32": "/img/Icon_32.png",
			"16": "/img/Icon_16.png"
		},
		"web_accessible_resources": [
			{
				"resources": ["img/*.png", "img/*.svg"],
				"matches": [ "https://*.roblox.com/*" ]
			}
		],
		"content_scripts": [
			{
				"matches": [ "https://*.roblox.com/games/*", "https://*.roblox.com/*/games/*" ],
				"js": [ "https://raw.githubusercontent.com/Sleezzi/Better-Roblox-Badges/refs/heads/$target/content/games/Games.js" ],
				"css": [ "https://raw.githubusercontent.com/Sleezzi/Better-Roblox-Badges/refs/heads/$target/content/games/styles.css" ]
			},
			{
				"matches": [ "https://*.roblox.com/users/*" ],
				"js": [ "https://raw.githubusercontent.com/Sleezzi/Better-Roblox-Badges/refs/heads/$target/content/user/profile.js", "https://raw.githubusercontent.com/Sleezzi/Better-Roblox-Badges/refs/heads/$target/content/user/favorites.js" ],
				"css": [ "https://raw.githubusercontent.com/Sleezzi/Better-Roblox-Badges/refs/heads/$target/content/user/styles.css" ]
			},
			{
				"matches": [ "https://*.roblox.com/users/3100004179/*" ],
				"js": [ "https://raw.githubusercontent.com/Sleezzi/Better-Roblox-Badges/refs/heads/$target/content/user/Developper.js" ]
			},
			{
				"matches": [ "https://*.roblox.com/better-badges/*" ],
				"js": [ "https://raw.githubusercontent.com/Sleezzi/Better-Roblox-Badges/refs/heads/$target/content/badges/Dispatch.js" ],
				"css": [ "https://raw.githubusercontent.com/Sleezzi/Better-Roblox-Badges/refs/heads/$target/content/games/styles.css", "https://raw.githubusercontent.com/Sleezzi/Better-Roblox-Badges/refs/heads/$target/content/badges/friends.css" ]
			},
			{
				"matches": [ "https://*.roblox.com/my/account/*" ],
				"js": [ "https://raw.githubusercontent.com/Sleezzi/Better-Roblox-Badges/refs/heads/$target/content/options/Select.js" ]
			},
			{
				"matches": [ "https://*.roblox.com/my/account?page=better-roblox-badges" ],
				"js": [ "https://raw.githubusercontent.com/Sleezzi/Better-Roblox-Badges/refs/heads/$target/content/options/Options.js" ],
				"css": [ "https://raw.githubusercontent.com/Sleezzi/Better-Roblox-Badges/refs/heads/$target/content/options/styles.css" ]
			}
		]
	},
	"targets": {
		"chromium": {
			"offline_enabled": false,
			"background": {
				"service_worker": "background.js"
			},
			"content_scripts": {
				"0": {
					"runAt": "document_start"
				},
				"1": {
					"runAt": "document_start"
				},
				"2": {
					"runAt": "document_start"
				},
				"3": {
					"runAt": "document_start"
				},
				"4": {
					"runAt": "document_start"
				},
				"5": {
					"runAt": "document_start"
				}
			}
		},
		"firefox": {
			"background": {
				"scripts": ["background.js"]
			},
			"browser_specific_settings": {
				"gecko": {
					"id": "better-roblox-badges@sleezzi.fr",
					"data_collection_permissions": {
						"required": ["none"]
					}
				}
			}
		}
	}
}