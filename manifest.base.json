{
	"base": {
		"manifest_version": 3,
		"name": "__MSG_name__",
		"description": "__MSG_description__",
		"default_locale": "en",
		"version": "1.0.5",
		"author": "Sleezzi",
		"homepage_url": "https://sleezzi.fr",
		"action": {
			"default_title": "Open settings",
			"default_popup": ""
		},
		"icons": {
			"128": "/img/Icon_128.png",
			"48": "/img/Icon_48.png",
			"32": "/img/Icon_32.png",
			"16": "/img/Icon_16.png"
		},
		"web_accessible_resources": [
			{
				"resources": ["img/*.png", "img/*.svg"],
				"matches": [ "https://*.roblox.com/*" ]
			}
		]
	},
	"targets": {
		"chrome": {
			"offline_enabled": false,
			"background": {
				"service_worker": "background.js"
			},
			"content_scripts": [
				{
					"matches": [ "https://*.roblox.com/games/*", "https://*.roblox.com/*/games/*" ],
					"js": [ "/content/games/games.js" ],
					"css": [ "/content/games/styles.css" ],
					"runAt": "document_start"
				},
				{
					"matches": [ "https://*.roblox.com/users/*" ],
					"js": [ "/content/user/profile.js", "/content/user/favorites.js" ],
					"css": [ "/content/user/styles.css" ],
					"runAt": "document_start"
				},
				{
					"matches": [ "https://*.roblox.com/users/3100004179/*" ],
					"js": [ "/content/user/developper.js" ],
					"runAt": "document_start"
				},
				{
					"matches": [ "https://*.roblox.com/better-badges/*" ],
					"js": [ "/content/badges/dispatch.js" ],
					"css": [ "/content/games/styles.css", "/content/badges/styles.css" ],
					"runAt": "document_start"
				},
				{
					"matches": [ "https://*.roblox.com/my/account/*" ],
					"js": [ "/content/options/select.js" ],
					"runAt": "document_start"
				},
				{
					"matches": [ "https://*.roblox.com/my/account?page=better-roblox-badges" ],
					"js": [ "/content/options/options.js" ],
					"css": [ "/content/options/styles.css" ],
					"runAt": "document_start"
				}
			]
		},
		"firefox": {
			"background": {
				"scripts": ["background.js"]
			},
			"content_scripts": [
				{
					"matches": [ "*://*.roblox.com/*" ],
					"css": [ "/content/global/styles.css" ]
				},
				{
					"matches": [ "*://*.roblox.com/games/*", "*://*.roblox.com/*/games/*" ],
					"js": [ "/content/games/Games.js" ],
					"css": [ "/content/games/styles.css", "/content/badges/styles.css" ]
				},
				{
					"matches": [ "*://*.roblox.com/users/*" ],
					"js": [ "/content/user/profile.js", "/content/user/favorites.js" ],
					"css": [ "/content/user/styles.css" ]
				},
				{
					"matches": [ "*://*.roblox.com/users/3100004179/*" ],
					"js": [ "/content/user/Developper.js" ]
				},
				{
					"matches": [ "*://*.roblox.com/better-badges/*" ],
					"js": [ "/content/badges/Dispatch.js" ],
					"css": [ "/content/games/styles.css", "/content/badges/styles.css" ]
				},
				{
					"matches": [ "*://*.roblox.com/my/account*" ],
					"js": [ "/content/options/Select.js" ]
				},
				{
					"matches": [ "*://*.roblox.com/my/account?page=better-roblox-badges" ],
					"js": [ "/content/options/Options.js" ],
					"css": [ "/content/options/styles.css" ]
				}
			],
			"browser_specific_settings": {
				"gecko": {
					"id": "better-roblox-badges@sleezzi.fr"
				}
			}
		}
	}
}