{
	"compilerOptions": {
		"jsx": "react-jsx",
		"strict": true,
		"module": "commonjs",
		"target": "ES2024",
		"esModuleInterop": true,
		"sourceMap": false,
		"outDir": "./build",
		"noEmitOnError": true,
		"typeRoots": [ "node_modules/@types" ],
		"types": ["chrome"]
	},
	"include": [
		"src/**/*"
	],
	"exclude": [
		"node_modules",
		"build"
	]
}